{
  "name": "doof",
  "version": "0.1.0",
  "description": "Doof-to-C++ transpiler",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "doof": "dist/bin.js"
  },
  "files": [
    "dist",
    "doof_observer_platform.h",
    "doof_observer_runtime.h",
    "doof_runtime.h",
    "observer-ui",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node dist/bin.js",
    "dev:install-global": "node scripts/local-global-dev.mjs install",
    "dev:uninstall-global": "node scripts/local-global-dev.mjs uninstall",
    "build:solitaire:mac": "bash scripts/build-solitaire-macos.sh",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:selfhost": "npm run build && node dist/bin.js test selfhost",
    "test:selfhost:coverage": "npm run build && node dist/bin.js test selfhost --coverage --coverage-output build/coverage/selfhost/selfhost.json",
    "test:release": "node scripts/release-gate.mjs",
    "generate:std-catalog": "node scripts/generate-std-catalog.mjs",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@andrew24601/reckon": "^0.1.2",
    "plist": "^3.1.0"
  }
}
