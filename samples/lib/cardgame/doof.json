{
  "name": "boardgame",
  "version": "0.1.0",
  "license": "ISC",
  "build": {
    "native": {
      "includePaths": ["."],
      "sourceFiles": [
        "engine/render/MetalRenderer.mm",
        "engine/render/TextureLoader.mm",
        "engine/render/TextureRegistry.mm",
        "engine/math/MathUtil.cpp"
      ],
      "frameworks": ["Foundation", "Metal", "QuartzCore", "ImageIO"],
      "macos": {
        "sourceFiles": [
          "native_boardgame_host.mm"
        ],
        "frameworks": ["Cocoa"],
        "pkgConfigPackages": ["sdl3"],
        "defines": ["SDL_MAIN_HANDLED"]
      },
      "iosSimulator": {
        "sourceFiles": [
          "ios_boardgame_host.mm"
        ],
        "frameworks": ["UIKit", "CoreGraphics"]
      },
      "iosDevice": {
        "sourceFiles": [
          "ios_boardgame_host.mm"
        ],
        "frameworks": ["UIKit", "CoreGraphics"]
      }
    }
  },
  "dependencies": {}
}
