{
  "name": "solitaire-sample",
  "version": "0.1.0",
  "license": "ISC",
  "target": "macos-app",
  "executable": "DoofSolitaire",
  "title": "Doof Solitaire",
  "icon": "app-icon.png",
  "build": {
    "macosApp": {
      "bundleId": "dev.doof.solitaire",
      "version": "1.0",
      "category": "public.app-category.games",
      "resources": [
        { "from": "images/*", "to": "images" }
      ]
    },
    "iosApp": {
      "bundleId": "doof.Solitaire",
      "version": "1.0",
      "resources": [
        { "from": "images/*", "to": "samples/solitaire/images" }
      ],
      "minimumDeploymentTarget": "16.0"
    }
  },
  "dependencies": {
    "cardgame": {
      "path": "../lib/cardgame"
    }
  }
}
